source ~/vim/vimrc

""" minimalistic setting (without plugin)

"set autoindent
"set tabstop=4
"set shiftwidth=4
"set autoindent
"set number
"set relativenumber
"set mouse=a
"colorscheme default
"set list lcs=tab:\|\   
"set wrap
"set conceallevel=2
"set concealcursor=c

"map <C-h> <C-w>h
"map <C-j> <C-w>j
"map <C-k> <C-w>k
"map <C-l> <C-w>l
"map <C-left> <C-w>h
"map <C-down> <C-w>j
"map <C-up> <C-w>k
"map <C-right> <C-w>l

"command W w
"command Q q
"command WQ wq
"command Wq wq

"autocmd BufWritePost *.c,*.cpp,*.h silent! !ctags -R &

"syntax on

" hi ErrorMsg ctermfg=red ctermbg=black
" hi Error ctermfg=red ctermbg=black
" hi Search ctermfg=black
